{
  "info": {
    "name": "PrimeTrade Backend API",
    "description": "API collection for authentication and task management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullname", "value": "John Doe", "type": "text" },
                { "key": "username", "value": "johndoe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "secret123", "type": "text" },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/users/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "users", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/users/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "users", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Buy groceries\",\n    \"description\": \"Milk, Bread, Cheese\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "tasks"]
            }
          }
        },
        {
          "name": "Get Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "http://localhost:8000/api/v1/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "tasks"]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/tasks/TASK_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "tasks", "TASK_ID_HERE"]
            }
          }
        },
        {
          "name": "Delete Task (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "http://localhost:8000/api/v1/tasks/TASK_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "tasks", "TASK_ID_HERE"]
            }
          }
        }
      ]
    }
  ]
}
